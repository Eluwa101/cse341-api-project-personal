@baseUrl = http://localhost:8080

### Get all students
GET {{baseUrl}}/students

### Get a single student by id
GET {{baseUrl}}/students/PUT_STUDENT_ID_HERE

### Create a student
POST {{baseUrl}}/students
Content-Type: application/json

{
  "firstName": "Test",
  "lastName": "Student",
  "email": "test.student@example.com",
  "phone": "+2349000000000",
  "role": "student",
  "city": "Aba",
  "state": "Abia",
  "country": "Nigeria",
  "course": "cse341"
}

### Update a student
PUT {{baseUrl}}/students/PUT_STUDENT_ID_HERE
Content-Type: application/json

{
  "firstName": "Updated",
  "lastName": "Student",
  "email": "updated.student@example.com",
  "phone": "+2349000000001",
  "role": "student",
  "city": "Lagos",
  "state": "Lagos",
  "country": "Nigeria",
  "course": "cse341"
}

### Delete a student
DELETE {{baseUrl}}/students/PUT_STUDENT_ID_HERE

### Get all courses
GET {{baseUrl}}/courses

### Get a single course by id
GET {{baseUrl}}/courses/PUT_COURSE_ID_HERE

### Create a course
POST {{baseUrl}}/courses
Content-Type: application/json

{
  "title": "English",
  "description": "Learn American English.",
  "instructorId": "u001",
  "level": "Beginner",
  "price": 49.99,
  "lessonsCount": 25,
  "rating": 4.7,
  "enrolledStudents": 320
}

### Update a course
PUT {{baseUrl}}/courses/PUT_COURSE_ID_HERE
Content-Type: application/json

{
  "title": "Mathematics",
  "description": "Master the fundamentals of mathematics.",
  "instructorId": "u002",
  "level": "Intermediate",
  "price": 79.99,
